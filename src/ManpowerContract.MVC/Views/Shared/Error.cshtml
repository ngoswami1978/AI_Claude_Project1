@{
    ViewData["Title"] = "Error";
    var statusCode = ViewBag.StatusCode ?? 500;
    var message = ViewBag.Message ?? "An unexpected error occurred.";
}

<div class="access-denied">
    <i class="fas fa-exclamation-triangle" style="color: var(--primary);"></i>
    <h2>Error @statusCode</h2>
    <p>@message</p>
    <a href="@Url.Action("Index", "Dashboard")" class="btn btn-primary">
        <i class="fas fa-arrow-left me-1"></i>Back to Dashboard
    </a>
</div>
