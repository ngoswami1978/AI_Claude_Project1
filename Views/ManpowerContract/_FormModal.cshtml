@model ManpowerContract.ViewModels.ManpowerContractViewModel

<div class="modal fade" id="contractModal" tabindex="-1" aria-labelledby="contractModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header" style="background:#009688;color:#fff;">
                <h5 class="modal-title" id="contractModalLabel">
                    <i class="bi bi-file-earmark-text"></i>
                    <span id="modalTitleText">Add New Contract</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form id="contractForm" novalidate>
                    <input type="hidden" id="contractId" value="0" />

                    <div class="row g-3">

                        <!-- Year -->
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Year <span class="text-danger">*</span></label>
                            <input type="number" id="year" class="form-control form-control-sm"
                                   placeholder="e.g. 2026" min="2000" max="2100" required />
                            <div class="invalid-feedback">Year is required.</div>
                        </div>

                        <!-- Month -->
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Month <span class="text-danger">*</span></label>
                            <select id="month" class="form-select form-select-sm select2-modal" required>
                                <option value="">Select Month</option>
                            </select>
                            <div class="invalid-feedback">Month is required.</div>
                        </div>

                        <!-- RCO -->
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">RCO <span class="text-danger">*</span></label>
                            <input type="text" id="rco" class="form-control form-control-sm"
                                   placeholder="e.g. COE" maxlength="100" required />
                            <div class="invalid-feedback">RCO is required.</div>
                        </div>

                        <!-- Division -->
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Division <span class="text-danger">*</span></label>
                            <input type="text" id="division" class="form-control form-control-sm"
                                   placeholder="Enter Division" maxlength="200" required />
                            <div class="invalid-feedback">Division is required.</div>
                        </div>

                        <!-- Group Company -->
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Group Company <span class="text-danger">*</span></label>
                            <select id="groupCompanyId" class="form-select form-select-sm select2-modal" required>
                                <option value="">Select Group Company</option>
                            </select>
                            <div class="invalid-feedback">Group Company is required.</div>
                        </div>

                        <!-- Plant Name -->
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Plant Name <span class="text-danger">*</span></label>
                            <select id="plantId" class="form-select form-select-sm select2-modal" required>
                                <option value="">Select Plant</option>
                            </select>
                            <div class="invalid-feedback">Plant Name is required.</div>
                        </div>

                        <!-- Plant Country (auto-filled) -->
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Plant Country</label>
                            <input type="text" id="plantCountry" class="form-control form-control-sm bg-light"
                                   placeholder="Auto-filled" readonly />
                        </div>

                        <!-- ERP Supplier Name -->
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">ERP Supplier Name <span class="text-danger">*</span></label>
                            <select id="supplierId" class="form-select form-select-sm select2-modal" required>
                                <option value="">Select Supplier</option>
                            </select>
                            <div class="invalid-feedback">ERP Supplier Name is required.</div>
                        </div>

                        <!-- Global Supplier Name -->
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Global Supplier Name <span class="text-danger">*</span></label>
                            <input type="text" id="globalSupplierName" class="form-control form-control-sm"
                                   placeholder="Enter Global Supplier Name" maxlength="200" />
                        </div>

                        <!-- Supplier Country -->
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Supplier Country</label>
                            <input type="text" id="supplierCountry" class="form-control form-control-sm"
                                   placeholder="Enter Supplier Country" maxlength="100" />
                        </div>

                        <!-- Supplier Name Remarks -->
                        <div class="col-md-12">
                            <label class="form-label fw-semibold">Supplier Name Remarks</label>
                            <textarea id="supplierNameRemarks" class="form-control form-control-sm"
                                      rows="2" maxlength="500" placeholder="Enter any remarks..."></textarea>
                        </div>

                        <!-- Annual Supplier Spend -->
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Annual Supplier Spend <span class="text-danger">*</span></label>
                            <input type="number" id="annualSupplierSpend" class="form-control form-control-sm"
                                   placeholder="0.00" min="0" step="0.01" required />
                            <div class="invalid-feedback">Annual Supplier Spend is required.</div>
                        </div>

                        <!-- Currency -->
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Currency <span class="text-danger">*</span></label>
                            <select id="currencyId" class="form-select form-select-sm select2-modal" required>
                                <option value="">Select Currency</option>
                            </select>
                            <div class="invalid-feedback">Currency is required.</div>
                        </div>

                        <!-- Contracted -->
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Contracted</label>
                            <select id="contracted" class="form-select form-select-sm select2-modal">
                                <option value="">Select</option>
                                <option value="Yes">Yes</option>
                                <option value="No">No</option>
                            </select>
                        </div>

                        <!-- Worker Type -->
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Worker Type</label>
                            <select id="workerType" class="form-select form-select-sm select2-modal">
                                <option value="">Select Worker Type</option>
                            </select>
                        </div>

                        <!-- Contracted Start Date -->
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Contracted Start Date <span class="text-danger">*</span></label>
                            <input type="date" id="contractedStartDate" class="form-control form-control-sm" required />
                            <div class="invalid-feedback">Start Date is required.</div>
                        </div>

                        <!-- Contracted End Date -->
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Contracted End Date <span class="text-danger">*</span></label>
                            <input type="date" id="contractedEndDate" class="form-control form-control-sm" required />
                            <div class="invalid-feedback">End Date is required.</div>
                        </div>

                    </div><!-- /row -->
                </form>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle"></i> Close
                </button>
                <button type="button" class="btn btn-sm px-4" style="background:#009688;color:#fff;" onclick="SaveRecord()">
                    <i class="bi bi-save"></i> Save
                </button>
            </div>

        </div>
    </div>
</div>
